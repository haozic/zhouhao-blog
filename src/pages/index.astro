---
import { Image } from 'astro:assets'

import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#629D43'>
  <main class='w-full'>
    {/* Hero Header - 居中布局 */}
    <header class='mb-8 pb-6 md:mb-12 md:pb-8 border-b border-border'>
      <div class='flex flex-col items-center gap-4 md:gap-6'>
        {/* Avatar */}
        <div class='w-32 h-32 md:w-40 md:h-40 overflow-hidden rounded-full flex items-center justify-center bg-muted/30 border-2 border-border'>
          <Image
            src={images[imagePath]()}
            alt={config.logo.alt ?? 'Avatar'}
            class='w-full h-full object-contain block'
            loading='eager'
            fetchpriority='high'
          />
        </div>

        {/* Title */}
        <h1 class='text-3xl md:text-5xl font-light text-foreground m-0 leading-tight tracking-tight site-title text-center'>
          {config.author}
        </h1>

        {/* Description */}
        <div class='text-sm md:text-base font-serif text-foreground/80 leading-relaxed max-w-xl text-center'>
          <span class='text-primary/50 text-lg md:text-xl leading-none mr-2'>"</span>
          {config.description}
          <span class='text-primary/50 text-lg md:text-xl leading-none ml-2'>"</span>
        </div>

        {/* GitHub link */}
        <a
          href='https://github.com/haozic/zhouhao-blog'
          target='_blank'
          rel='noopener noreferrer'
          class='flex items-center gap-x-2 text-sm text-muted-foreground hover:text-primary transition-colors'
        >
          <svg aria-hidden='true' class='size-4' width='22' height='22' viewBox='0 0 24 24' fill='currentColor'>
            <path fill='none' d='M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' />
          </svg>
          <span>GitHub: haozic</span>
        </a>
      </div>
    </header>

    {/* Main Content: Posts + Sidebar */}
    <div class='grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 md:gap-8'>
      {/* Left: Posts List */}
      <main class='flex flex-col'>
        {/* Section Header */}
        <div class='flex items-center gap-2 mb-4 md:mb-5 pb-2 md:pb-3 border-b border-border'>
          <svg aria-hidden='true' class='size-5' width='22' height='22' viewBox='0 0 24 24' fill='currentColor'>
            <path d='M18 2a2 2 0 0 1 2 2v11.586A2 2 0 0 1 19.414 17L15 21.414a2 2 0 0 1-1.414.586H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zm0 2H6v16h6v-4.5a1.5 1.5 0 0 1 1.5-1.5H18zm-.414 12H14v3.586zM10 11a1 1 0 1 1 0 2H9a1 1 0 1 1 0-2zm5-4a1 1 0 1 1 0 2H9a1 1 0 1 1 0-2Z' />
          </svg>
          <span class='text-xs text-muted-foreground uppercase tracking-wider'>最新文章</span>
        </div>

        {/* Post List */}
        <div class='flex flex-col gap-0.5'>
          {allPostsByDate.length > 0
            ? allPostsByDate.map((post) => (
                <a href={`/blog/${post.id}`} class='block no-underline group relative z-10'>
                  <article class='relative flex items-baseline justify-between gap-3 py-2.5 md:py-3 border-b border-border last:border-b-0 transition-colors hover:text-primary cursor-pointer'>
                    <div class='text-base md:text-lg font-normal text-foreground m-0 leading-snug transition-colors group-hover:text-primary line-clamp-2'>
                      {post.data.title ?? post.id}
                    </div>
                    <time class='text-xs md:text-sm text-muted-foreground tabular-nums shrink-0'>
                      {post.data.publishDate ? new Date(post.data.publishDate).toLocaleDateString('zh-CN') : ''}
                    </time>
                  </article>
                </a>
              ))
            : <p class='text-muted-foreground'>暂无文章。</p>}
        </div>

        {allPostsByDate.length > 0 && (
          <div class='mt-4 md:mt-5 pt-3 md:pt-4 border-t border-border'>
            <a href='/blog' class='text-sm text-foreground no-underline transition-colors hover:text-primary'>
              全部文章 →
            </a>
          </div>
        )}
      </main>

      {/* Right: Sidebar */}
      <aside class='hidden md:flex flex-col gap-3 md:gap-6 md:w-56 lg:w-64'>
        {/* 站点统计 */}
        <div class='receipt-style'>
          <div class='border-l border-r border-dashed border-border px-3 md:px-4'>
            <div class='text-xs text-muted-foreground uppercase tracking-wider flex items-center justify-between gap-2 pt-3 pb-2 mb-2 md:pt-4 md:mb-3 border-b-2 border-dashed border-border'>
              <div class='flex items-center gap-2'>
                <svg aria-hidden='true' class='size-4' width='22' height='22' viewBox='0 0 48 48' fill='currentColor'>
                  <g fill='none' stroke='currentColor' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'>
                    <path d='M39.743 44.461c2.555-.208 4.51-2.163 4.718-4.718C44.723 36.515 45 31.364 45 24s-.277-12.515-.539-15.743c-.208-2.555-2.163-4.51-4.718-4.718C36.515 3.277 31.364 3 24 3s-12.515.277-15.743.539c-2.555.208-4.51 2.163-4.718 4.718C3.277 11.485 3 16.636 3 24s.277 12.515.539 15.743c.208 2.555 2.163 4.51 4.718 4.718C11.485 44.723 16.636 45 24 45s12.515-.277 15.743-.539' />
                    <path d='M11 11h10m-10 6h6' />
                  </g>
                </svg>
                <span>站点统计</span>
              </div>
              <span class='normal-case'>from 2024/01/01</span>
            </div>
            <div class='flex flex-col gap-1 text-sm'>
              <div class='flex justify-between items-center py-1 border-b border-dashed border-border'>
                <span class='text-muted-foreground text-xs md:text-sm'>文章</span>
                <span class='text-foreground font-semibold tabular-nums text-xs md:text-sm'>{allPostsByDate.length}</span>
              </div>
              <div class='flex justify-between items-center py-1 border-b border-dashed border-border'>
                <span class='text-muted-foreground text-xs md:text-sm'>总访问量</span>
                <span class='text-foreground font-semibold tabular-nums text-xs md:text-sm' id='vercount_value_site_pv'>Loading</span>
              </div>
              <div class='flex justify-between items-center py-1 pb-3 md:pb-4'>
                <span class='text-muted-foreground text-xs md:text-sm'>总访客量</span>
                <span class='text-foreground font-semibold tabular-nums text-xs md:text-sm' id='vercount_value_site_uv'>Loading</span>
              </div>
            </div>
          </div>
        </div>

        {/* 联系我 */}
        <div class='px-3 md:px-5'>
          <div class='border-l border-r border-dashed border-border px-3 md:px-4'>
            <div class='text-xs text-muted-foreground uppercase tracking-wider flex items-center gap-2 pt-3 pb-2 mb-2 md:pt-4 md:mb-3 border-b-2 border-dashed border-border'>
              <svg aria-hidden='true' class='size-4' width='22' height='22' viewBox='0 0 24 24' fill='currentColor'>
                <path fill='none' stroke='currentColor' stroke-linejoin='round' d='M21.5 12a14.5 14.5 0 1 1-29 0 14.5 14.5 0 0 1 29 0z' stroke-width='1' />
                <path fill='none' stroke='currentColor' stroke-linecap='round' d='M12 8v4l3 3' stroke-width='1' />
              </svg>
              <span>联系我</span>
            </div>
            <div class='flex flex-row flex-wrap gap-2 md:gap-3 pb-3 md:pb-4'>
              <a
                href='https://github.com/haozic/zhouhao-blog'
                target='_blank'
                rel='noopener noreferrer'
                class='flex items-center gap-1 text-xs md:text-sm text-muted-foreground no-underline transition-colors hover:text-primary py-1'
              >
                <svg aria-hidden='true' class='size-4' width='22' height='22' viewBox='0 0 24 24' fill='currentColor'>
                  <path fill='none' d='M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' />
                </svg>
                <span class='hidden md:inline'>GitHub</span>
              </a>
              <a
                href='/rss.xml'
                target='_blank'
                rel='noopener noreferrer'
                class='flex items-center gap-1 text-xs md:text-sm text-primary no-underline transition-colors hover:text-primary/90 py-1'
              >
                <svg aria-hidden='true' class='size-4' width='22' height='22' viewBox='0 0 24 24' fill='currentColor'>
                  <path fill='none' d='M4 11a11 11 0 0 1 11 11' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' />
                  <path fill='none' d='M4 4a16 16 0 0 1 16 16' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' />
                  <circle cx='5' cy='19' r='1' fill='currentColor' />
                </svg>
                <span class='hidden md:inline'>RSS</span>
              </a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </main>
</PageLayout>

<script defer src='https://events.vercount.one/js'></script>
